<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="250"> <!-- 动画时长，建议与你的 handler 延迟时间(250ms)匹配 -->

    <translate
        android:fromXDelta="-100%"
        android:toXDelta="0%" />

    <!-- 可选：添加一点淡入效果，让过渡更自然 -->
